# ── Server ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────
# From Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service-role key: backend-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Apify ─────────────────────────────────────────────────────────────
# From Apify Console → Settings → Integrations → API token
APIFY_TOKEN=apify_api_xxx

# ── Behaviour ─────────────────────────────────────────────────────────
# Phase 2: automatically fail over to the next-priority actor on failure
FAILOVER_ENABLED=false
# Run jobs synchronously (true) or via in-memory async queue (false)
SYNC_JOBS=false
